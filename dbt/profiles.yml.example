# Copy to ~/.dbt/profiles.yml or set DBT_PROFILES_DIR to a directory containing this file.
investor_profiling:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: "{{ env_var('DATABRICKS_CATALOG', 'investor_profiling') }}"
      schema: "{{ env_var('DATABRICKS_SCHEMA', 'investor_profiling') }}"
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4
